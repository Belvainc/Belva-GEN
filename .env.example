# ============================================================================
# Belva-GEN Environment Configuration
# ============================================================================
# Copy this file to .env.local and fill in required values.
# Variables with defaults can be omitted for local development.
# ============================================================================

# ─── Core ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ─── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Required. Use `make infra-up` to start local PostgreSQL via Docker.
DATABASE_URL=postgresql://belva:belva@localhost:5432/belva_dev

# ─── Redis ─────────────────────────────────────────────────────────────────────
# Required for cache + job queues. Use `make infra-up` for local Redis.
REDIS_URL=redis://localhost:6379

# ─── Jira MCP (Optional) ──────────────────────────────────────────────────────
# Omit for local development — stub clients are used when absent.
# JIRA_BASE_URL=https://your-org.atlassian.net
# JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=BELVA

# ─── Slack MCP (Optional) ─────────────────────────────────────────────────────
# Omit for local development — stub clients are used when absent.
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_APPROVAL_CHANNEL=#belva-approvals
SLACK_NOTIFICATION_CHANNEL=#belva-notifications

# ─── Webhook Security ─────────────────────────────────────────────────────────
# Minimum 32 characters. Used for HMAC-SHA256 webhook signature verification.
WEBHOOK_SECRET=dev-webhook-secret-must-be-32-chars-min

# ─── OpenTelemetry (Optional) ─────────────────────────────────────────────────
# Omit for local development — traces go to stdout.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=belva-gen
