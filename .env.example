# ============================================================================
# Belva-GEN Environment Configuration
# ============================================================================
# Copy this file to .env.local and fill in required values.
# Variables with defaults can be omitted for local development.
#
# Infrastructure: brew services (PostgreSQL@15, Redis)
#   make infra-up      Start services
#   make db-create     Create belva_gen_dev database
#   make db-migrate    Run Prisma migrations
#   make db-seed       Seed admin user
# ============================================================================

# ─── Core ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ─── Database (PostgreSQL@15 via Homebrew) ────────────────────────────────────
# Local: james user, no password (peer auth), belva_gen_dev database.
# Separate from belva_goat_dev to avoid collision.
DATABASE_URL=postgresql://james@localhost:5432/belva_gen_dev

# ─── Redis (via Homebrew) ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Authentication ──────────────────────────────────────────────────────────
# JWT secret for token signing. Minimum 32 characters.
JWT_SECRET=dev-jwt-secret-must-be-at-least-32-characters

# AES-256-GCM encryption key for project credentials. Must be 64 hex chars (32 bytes).
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ─── Seed Admin User ────────────────────────────────────────────────────────
# Used by `make db-seed` to create the initial admin user.
SEED_ADMIN_EMAIL=admin@belva.dev
SEED_ADMIN_PASSWORD=admin-dev-password-change-me

# ─── Jira MCP (Optional) ──────────────────────────────────────────────────────
# Omit for local development — stub clients are used when absent.
# JIRA_BASE_URL=https://belva.atlassian.net
# JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=BELVA

# ─── Slack Notifications (Optional) ───────────────────────────────────────────
# Omit for local development — stub clients are used when absent.
# Use Incoming Webhook URL (not Bot Token) for one-way notifications.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx

# ─── Webhook Security ─────────────────────────────────────────────────────────
# Minimum 32 characters. Used for HMAC-SHA256 webhook signature verification.
WEBHOOK_SECRET=dev-webhook-secret-must-be-32-chars-min

# ─── OpenTelemetry (Optional) ─────────────────────────────────────────────────
# Omit for local development — traces go to stdout.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=belva-gen
