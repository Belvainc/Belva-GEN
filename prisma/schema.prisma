// ============================================================================
// Belva-GEN Database Schema
// ============================================================================
// PostgreSQL via Prisma ORM. Replaces all in-memory Map<> state with durable
// storage. Run `npx prisma migrate dev` after schema changes.
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ──────────────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  DEACTIVATED
}

model User {
  id            String       @id @default(uuid())
  email         String       @unique
  passwordHash  String
  name          String
  role          UserRole     @default(USER)
  status        UserStatus   @default(ACTIVE)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // Relations
  sessions      Session[]
  projects      UserProject[]
  approvals     Approval[]       @relation("ApprovalDecider")
  auditLogs     AuditLog[]

  @@map("users")
}

model Session {
  id            String    @id @default(uuid())
  userId        String
  expiresAt     DateTime
  lastActiveAt  DateTime  @default(now())
  createdAt     DateTime  @default(now())

  // Relations
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// ─── Projects ──────────────────────────────────────────────────────────────────

model Project {
  id                  String   @id @default(uuid())
  name                String
  slug                String   @unique
  description         String?
  jiraBaseUrl         String?
  jiraUserEmail       String?
  jiraProjectKey      String?
  confluenceSpaceKey  String?
  githubRepo          String?  // "owner/repo" format
  metadata            Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  users               UserProject[]
  credentials         ProjectCredential[]
  pipelines           Pipeline[]
  agents              Agent[]
  auditLogs           AuditLog[]
  knowledgeEntries    KnowledgeEntry[]

  @@map("projects")
}

model ProjectCredential {
  id              String   @id @default(uuid())
  projectId       String
  key             String   // e.g. "jira_api_token", "github_token"
  encryptedValue  String   // AES-256-GCM encrypted
  iv              String   // Initialization vector (hex)
  authTag         String   // GCM authentication tag (hex)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, key])
  @@map("project_credentials")
}

model UserProject {
  userId      String
  projectId   String
  assignedAt  DateTime @default(now())

  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([userId, projectId])
  @@map("user_projects")
}

// ─── Agent Registry ──────────────────────────────────────────────────────────

enum AgentStatusValue {
  IDLE
  BUSY
  ERROR
  OFFLINE
}

model Agent {
  id              String           @id // e.g. "node-backend", "next-ux"
  name            String
  description     String
  status          AgentStatusValue @default(IDLE)
  currentTask     String?
  capabilities    Json             // AgentCapability shape
  ownedPaths      String[]
  lastHeartbeat   DateTime         @default(now())
  projectId       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Relations
  project         Project?         @relation(fields: [projectId], references: [id])
  pipelineStages  PipelineStage[]
  auditLogs       AuditLog[]

  @@map("agents")
}

// ─── Pipeline (Epic Lifecycle) ───────────────────────────────────────────────

enum PipelineStatus {
  FUNNEL
  REFINEMENT
  APPROVED
  IN_PROGRESS
  REVIEW
  DONE
}

model Pipeline {
  id              String          @id @default(uuid())
  epicKey         String          @unique // Jira ticket ref, e.g. "BELVA-042"
  status          PipelineStatus  @default(FUNNEL)
  revisionCount   Int             @default(0)
  metadata        Json?           // Additional context
  projectId       String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  project             Project?            @relation(fields: [projectId], references: [id])
  stages              PipelineStage[]
  approvals           Approval[]
  decomposition       TaskDecomposition?
  patternExtractions  PatternExtraction[]

  @@map("pipelines")
}

// ─── Task Decomposition (LLM-generated task graph) ───────────────────────────

model TaskDecomposition {
  id              String          @id @default(uuid())
  pipelineId      String          @unique
  taskGraph       Json            // Serialized TaskGraph with nodes and dependencies
  totalPoints     Int             // Sum of all task estimated points
  riskAreas       String[]        // LLM-identified risk areas
  affectedFiles   String[]        // Files expected to be modified
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  pipeline        Pipeline        @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@map("task_decompositions")
}

model PipelineStage {
  id              String          @id @default(uuid())
  pipelineId      String
  name            String
  status          String          @default("pending") // pending, in-progress, completed, failed
  order           Int
  agentId         String?
  metadata        Json?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  pipeline        Pipeline        @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  agent           Agent?          @relation(fields: [agentId], references: [id])

  @@map("pipeline_stages")
}

// ─── Approvals (HITL Governance) ─────────────────────────────────────────────

enum ApprovalType {
  CODE_REVIEW
  DEPLOY
  RISK
  PLAN
  STAKEHOLDER
  TEAM_CONFIRMATION
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

model Approval {
  id              String          @id @default(uuid())
  pipelineId      String
  type            ApprovalType
  status          ApprovalStatus  @default(PENDING)
  requestedBy     String          // Agent ID that requested
  decidedById     String?         // FK to User who decided
  decidedByLegacy String?         // Legacy: plain string identity (pre-auth migration)
  reason          String?         // Reviewer comment
  expiresAt       DateTime?
  decidedAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Plan details (stored for audit and display)
  planSummary     String?         @db.Text    // Human-readable plan description
  planHash        String?         // SHA-256 of plan for integrity verification
  affectedFiles   String[]        // List of files to be modified
  estimatedPoints Int?            // Total story points estimate
  riskLevel       String?         // 'low' | 'medium' | 'high'

  // Relations
  pipeline        Pipeline        @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  decidedByUser   User?           @relation("ApprovalDecider", fields: [decidedById], references: [id])

  @@index([pipelineId])
  @@index([status])
  @@map("approvals")
}

// ─── Audit Log ───────────────────────────────────────────────────────────────

model AuditLog {
  id              String          @id @default(uuid())
  action          String          // e.g. "agent.registered", "pipeline.transitioned"
  entityType      String          // e.g. "agent", "pipeline", "approval"
  entityId        String
  agentId         String?
  userId          String?         // User who performed the action (if human-initiated)
  projectId       String?         // Project scope (if applicable)
  payload         Json?           // Event-specific data
  createdAt       DateTime        @default(now())

  // Relations
  agent           Agent?          @relation(fields: [agentId], references: [id])
  user            User?           @relation(fields: [userId], references: [id])
  project         Project?        @relation(fields: [projectId], references: [id])

  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@index([userId])
  @@map("audit_logs")
}

// ─── Knowledge System (Stage 6: Learn) ──────────────────────────────────────

enum KnowledgeCategory {
  PATTERN
  GOTCHA
  DECISION
  OPTIMIZATION
}

enum KnowledgeStatus {
  DRAFT
  VALIDATED
  PROMOTED
  ARCHIVED
}

model KnowledgeEntry {
  id                String            @id @default(uuid())
  projectId         String?
  agentId           String?
  category          KnowledgeCategory
  title             String
  content           String            @db.Text
  sourceTicketRef   String?           // Originating Jira ticket
  confidence        Float             @default(0.5) // 0.0 to 1.0
  status            KnowledgeStatus   @default(DRAFT)
  promotedTo        String?           // Where promoted: "shared-memory", "rule", "skill"
  validatedCount    Int               @default(0)   // Number of builds that validated this
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  validatedAt       DateTime?

  // Relations
  project           Project?          @relation(fields: [projectId], references: [id])

  @@index([category])
  @@index([status])
  @@index([sourceTicketRef])
  @@map("knowledge_entries")
}

model PatternExtraction {
  id                  String          @id @default(uuid())
  pipelineId          String
  extractedPatterns   Json            // Array of extracted pattern summaries
  extractedAt         DateTime        @default(now())

  // Relations
  pipeline            Pipeline        @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@index([pipelineId])
  @@map("pattern_extractions")
}
